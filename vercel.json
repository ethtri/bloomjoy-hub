{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "bloomjoyusa.com"
        }
      ],
      "headers": {
        "Location": "https://www.bloomjoyusa.com/$1"
      },
      "status": 308
    },
    {
      "src": "/(login(?:/operator)?|reset-password|portal(?:/.*)?|admin(?:/.*)?)",
      "has": [
        {
          "type": "host",
          "value": "www.bloomjoyusa.com"
        }
      ],
      "headers": {
        "Location": "https://app.bloomjoyusa.com/$1"
      },
      "status": 308
    },
    {
      "src": "/",
      "has": [
        {
          "type": "host",
          "value": "app.bloomjoyusa.com"
        }
      ],
      "headers": {
        "Location": "https://www.bloomjoyusa.com/"
      },
      "status": 308
    },
    {
      "src": "/(machines(?:/.*)?|products(?:/.*)?|supplies|plus|resources|about|contact|privacy|terms|billing-cancellation|cart)",
      "has": [
        {
          "type": "host",
          "value": "app.bloomjoyusa.com"
        }
      ],
      "headers": {
        "Location": "https://www.bloomjoyusa.com/$1"
      },
      "status": 308
    },
    {
      "src": "/products/?",
      "headers": {
        "Location": "/machines"
      },
      "status": 308
    },
    {
      "src": "/products/(commercial-robotic-machine|mini|micro)/?",
      "headers": {
        "Location": "/machines/$1"
      },
      "status": 308
    },
    {
      "src": "/(portal|admin)(.*)",
      "headers": {
        "X-Robots-Tag": "noindex, nofollow, noarchive, nosnippet"
      },
      "continue": true
    },
    {
      "src": "/(login(?:/operator)?|reset-password|cart)",
      "headers": {
        "X-Robots-Tag": "noindex, nofollow, noarchive, nosnippet"
      },
      "continue": true
    },
    {
      "src": "/machines/(commercial-robotic-machine|mini|micro)/?",
      "dest": "/machines/$1.html"
    },
    {
      "src": "/(machines|supplies|plus|resources|about|contact|privacy|terms|billing-cancellation)/?",
      "dest": "/$1.html"
    },
    {
      "src": "/(cart|login(?:/operator)?|reset-password)/?",
      "dest": "/$1.html"
    },
    {
      "src": "/portal(?:/.*)?/?",
      "dest": "/portal.html"
    },
    {
      "src": "/admin(?:/.*)?/?",
      "dest": "/admin.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
