VITE_SUPABASE_ANON_KEY=
# Optional local dev helper for rendering Google's official GIS button
VITE_GOOGLE_CLIENT_ID=

# Server-only values (Supabase Edge Functions / backend only)
# WARNING: Never prefix these with VITE_.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUGAR_PRICE_ID=
# Stripe recurring unit price for Plus (set to $100/month per machine)
STRIPE_PLUS_PRICE_ID=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
