# Client-safe values (required by the SPA and exposed in the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional local dev helper for rendering Google's official GIS button
VITE_GOOGLE_CLIENT_ID=
# Optional GIS toggle. Default uses redirect-based Google sign-in flow.
VITE_USE_GIS_BUTTON=false
# Optional local-dev-only QA override for admin access (comma-separated emails).
# Ignored outside local development mode.
VITE_DEV_ADMIN_EMAILS=

# Server-only values (Supabase Edge Functions / backend only)
# WARNING: Never prefix these with VITE_.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Legacy bridge for member sugar pricing. Prefer STRIPE_SUGAR_MEMBER_PRICE_ID.
STRIPE_SUGAR_PRICE_ID=
STRIPE_SUGAR_MEMBER_PRICE_ID=
STRIPE_SUGAR_NON_MEMBER_PRICE_ID=
STRIPE_STICKS_PRICE_ID=
STRIPE_STICKS_MEMBER_PRICE_ID=
# Stripe recurring monthly price for Plus (set to $100/month)
STRIPE_PLUS_PRICE_ID=
# Optional local/dev-only support for localhost checkout, billing, and invite URLs.
BLOOMJOY_ALLOW_LOCAL_REDIRECT_URLS=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
INTERNAL_NOTIFICATION_FROM_EMAIL=
# Comma-separated additional internal recipients for quote/procurement/order notifications.
# Ethan and Ian are always included by the Edge Function email helper.
INTERNAL_NOTIFICATION_RECIPIENTS=etrifari@bloomjoysweets.com,ian@bloomjoysweets.com
VIMEO_ACCESS_TOKEN=
NAYAX_LYNX_API_TOKEN=

# Sales reporting automation (server-only)
REPORT_SCHEDULER_SECRET=
REPORTING_INGEST_URL=
REPORTING_INGEST_TOKEN=
REPORTING_ROW_HASH_SALT=
SUNZE_LOGIN_URL=
SUNZE_REPORTING_EMAIL=
SUNZE_REPORTING_PASSWORD=
SUNZE_INGEST_MAX_ROWS=20000
SUNZE_EXPECTED_MACHINE_COUNT=
SUNZE_SYNC_STALE_HOURS=30
SUNZE_REPORTING_TIMEZONE=America/Los_Angeles
GOOGLE_REFUNDS_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Nayax Lynx card lookup for refund correlation (server-only)
# Do not prefix with VITE_; never expose this token to the browser.
NAYAX_LYNX_BASE_URL=https://lynx.nayax.com/operational/v1
NAYAX_LYNX_API_TOKEN_TGPACI_USA_DB=
NAYAX_LOOKUP_WINDOW_HOURS=6
REFUND_NAYAX_CANDIDATE_TTL_HOURS=24
REFUND_REPLY_TO_EMAIL=info@bloomjoysweets.com
# Nayax card refund execution is fail-closed by default. Keep these server-only.
NAYAX_REFUND_EXECUTION_ENABLED=false
NAYAX_REFUND_EXECUTION_DRY_RUN=true
NAYAX_REFUND_EXECUTION_KILL_SWITCH=true
NAYAX_REFUND_EXECUTION_SPONSOR_GO_NO_GO=
NAYAX_REFUND_EXECUTION_PROVIDER_CONTRACT_CONFIRMED=false
# Exact account-validated Result/Status pairs and request settings. Leave blank
# until Nayax QA evidence is approved. Never prefix with VITE_.
NAYAX_REFUND_PROVIDER_CONTRACT_JSON=
NAYAX_REFUND_PROVIDER_TIMEOUT_MS=10000
NAYAX_REFUND_MAX_AMOUNT_CENTS=1000
NAYAX_REFUND_DAILY_AMOUNT_CAP_CENTS=5000
NAYAX_REFUND_DAILY_COUNT_CAP=10
NAYAX_REFUND_IDEMPOTENCY_SECRET=
# Scheduled refund reminders/escalations. May reuse REPORT_SCHEDULER_SECRET.
REFUND_AUTOMATION_SWEEP_SECRET=
REFUND_MORE_INFO_REMINDER_DAYS=2
REFUND_ESCALATION_DAYS=5

# WeCom internal alerting (server-only)
# CorpID from My Company -> Company Info
WECOM_CORP_ID=
# AgentId from App Management -> your app details
WECOM_AGENT_ID=
# Secret from App Management -> your app details (do not expose client-side)
WECOM_AGENT_SECRET=
# Optional comma-separated recipient user IDs for alert fanout
# Example: ethan.trifari,ops.manager
WECOM_ALERT_TO_USERIDS=
