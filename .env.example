# Client-safe values (required by the SPA and exposed in the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional local dev helper for rendering Google's official GIS button
VITE_GOOGLE_CLIENT_ID=
# Optional GIS toggle. Default uses redirect-based Google sign-in flow.
VITE_USE_GIS_BUTTON=false
# Optional local-dev-only QA override for admin access (comma-separated emails).
# Ignored outside local development mode.
VITE_DEV_ADMIN_EMAILS=
# Optional client-safe GA4 measurement ID for marketing attribution and page views.
VITE_GA4_MEASUREMENT_ID=

# Server-only values (Supabase Edge Functions / backend only)
# WARNING: Never prefix these with VITE_.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Legacy bridge for member sugar pricing. Prefer STRIPE_SUGAR_MEMBER_PRICE_ID.
STRIPE_SUGAR_PRICE_ID=
STRIPE_SUGAR_MEMBER_PRICE_ID=
STRIPE_SUGAR_NON_MEMBER_PRICE_ID=
STRIPE_STICKS_PRICE_ID=
# Stripe recurring monthly price for Plus (set to $100/month)
STRIPE_PLUS_PRICE_ID=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
INTERNAL_NOTIFICATION_FROM_EMAIL=
# Comma-separated internal recipients for quote/order notifications.
INTERNAL_NOTIFICATION_RECIPIENTS=etrifari@bloomjoysweets.com,ian@bloomjoysweets.com
VIMEO_ACCESS_TOKEN=

# WeCom internal alerting (server-only)
# CorpID from My Company -> Company Info
WECOM_CORP_ID=
# AgentId from App Management -> your app details
WECOM_AGENT_ID=
# Secret from App Management -> your app details (do not expose client-side)
WECOM_AGENT_SECRET=
# Optional comma-separated recipient user IDs for alert fanout
# Example: ethan.trifari,ops.manager
WECOM_ALERT_TO_USERIDS=
